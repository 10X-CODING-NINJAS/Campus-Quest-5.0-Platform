{
  "name": "campus-quest-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Campus Quest 5.0 - Production-ready competitive programming platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:electron": "turbo run dev --filter=@campus-quest/electron",
    "dev:backend": "turbo run dev --filter=@campus-quest/backend",
    "dev:admin": "turbo run dev --filter=@campus-quest/admin",
    "build:electron": "turbo run build --filter=@campus-quest/electron",
    "build:backend": "turbo run build --filter=@campus-quest/backend",
    "db:generate": "turbo run db:generate --filter=@campus-quest/backend",
    "db:migrate": "turbo run db:migrate --filter=@campus-quest/backend",
    "db:studio": "turbo run db:studio --filter=@campus-quest/backend",
    "db:seed": "turbo run db:seed --filter=@campus-quest/backend"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.0"
}
