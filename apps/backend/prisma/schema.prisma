// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ContestStatus {
  WAITING
  DIAGNOSTICS
  LOBBY
  LIVE
  PAUSED
  MISSION_MODE
  ENDED
}

enum SubmissionVerdict {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILE_ERROR
  SYSTEM_ERROR
}

enum Language {
  CPP
  JAVA
  PYTHON
  JAVASCRIPT
}

enum AntiCheatEventType {
  FOCUS_LOST
  FOCUS_GAINED
  FULLSCREEN_EXIT
  CLIPBOARD_ATTEMPT
  DEVTOOLS_OPEN
  RIGHT_CLICK_ATTEMPT
}

// ─── Contest State ────────────────────────────────────────────────────────────

model ContestState {
  id                 String        @id @default(cuid())
  status             ContestStatus @default(WAITING)
  startedAt          DateTime?
  pausedAt           DateTime?
  endedAt            DateTime?
  durationMinutes    Int           @default(180)
  isLeaderboardFrozen Boolean     @default(false)
  frozenAt           DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@map("contest_state")
}

// ─── Teams ────────────────────────────────────────────────────────────────────

model Team {
  id           String   @id @default(cuid())
  name         String   @unique
  username     String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions     Submission[]
  spiderSense     SpiderSense?
  missionProgress MissionProgress?
  leaderboard     Leaderboard?
  warnings        Warning[]
  announcements   AnnouncementRead[]

  @@map("teams")
}

// ─── Problems ─────────────────────────────────────────────────────────────────

model Problem {
  id             String   @id @default(cuid())
  order          Int      @unique
  title          String
  slug           String   @unique
  description    String
  inputFormat    String
  outputFormat   String
  constraints    String
  sampleInput    String
  sampleOutput   String
  timeLimit      Int      @default(2000)  // milliseconds
  memoryLimit    Int      @default(256)   // MB
  score          Int      @default(100)
  isHidden       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  testCases  TestCase[]
  submissions Submission[]

  @@map("problems")
}

// ─── Test Cases ───────────────────────────────────────────────────────────────

model TestCase {
  id        String   @id @default(cuid())
  problemId String
  input     String
  output    String
  isSample  Boolean  @default(false)
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@index([problemId])
  @@map("test_cases")
}

// ─── Submissions ──────────────────────────────────────────────────────────────

model Submission {
  id          String            @id @default(cuid())
  teamId      String
  problemId   String
  language    Language
  code        String
  verdict     SubmissionVerdict @default(PENDING)
  score       Int               @default(0)
  runtime     Int?              // milliseconds
  memory      Int?              // KB
  compileError String?
  testResults Json?             // detailed per-testcase results
  judgedAt    DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  team    Team    @relation(fields: [teamId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@index([teamId])
  @@index([problemId])
  @@index([verdict])
  @@map("submissions")
}

// ─── Spider Sense ─────────────────────────────────────────────────────────────

model SpiderSense {
  id        String   @id @default(cuid())
  teamId    String   @unique
  charges   Int      @default(3)
  usedOn    Int[]    // array of problem orders bypassed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])

  @@map("spider_sense")
}

// ─── Mission Progress ─────────────────────────────────────────────────────────

model MissionProgress {
  id              String   @id @default(cuid())
  teamId          String   @unique
  unlockedUntil   Int      @default(0)  // highest problem order solved
  latitude        String?
  longitude       String?
  riddleParts     String[] @default([])
  mapUnlocked     Boolean  @default(false)
  missionComplete Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])

  @@map("mission_progress")
}

// ─── Flags ────────────────────────────────────────────────────────────────────

model Flag {
  id          String   @id @default(cuid())
  value       String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions FlagSubmission[]

  @@map("flags")
}

model FlagSubmission {
  id        String   @id @default(cuid())
  teamId    String
  flagId    String?
  attempt   String
  isCorrect Boolean  @default(false)
  createdAt DateTime @default(now())

  flag Flag? @relation(fields: [flagId], references: [id])

  @@index([teamId])
  @@map("flag_submissions")
}

// ─── Leaderboard ─────────────────────────────────────────────────────────────

model Leaderboard {
  id          String   @id @default(cuid())
  teamId      String   @unique
  score       Int      @default(0)
  solved      Int      @default(0)
  penalty     Int      @default(0)  // time penalty in seconds
  lastSolvedAt DateTime?
  rank        Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team Team @relation(fields: [teamId], references: [id])

  @@map("leaderboard")
}

// ─── Warnings / Anti-cheat ────────────────────────────────────────────────────

model Warning {
  id             String             @id @default(cuid())
  teamId         String
  type           AntiCheatEventType
  count          Int                @default(1)
  metadata       Json?
  createdAt      DateTime           @default(now())

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId])
  @@map("warnings")
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reads AnnouncementRead[]

  @@map("announcements")
}

model AnnouncementRead {
  teamId         String
  announcementId String
  readAt         DateTime @default(now())

  team         Team         @relation(fields: [teamId], references: [id])
  announcement Announcement @relation(fields: [announcementId], references: [id])

  @@id([teamId, announcementId])
  @@map("announcement_reads")
}
