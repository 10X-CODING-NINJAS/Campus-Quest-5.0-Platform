# Backend Environment Variables
# Copy this to .env and fill in your values

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/campus_quest"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT="3001"
HOST="0.0.0.0"
NODE_ENV="development"
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-in-production"

# ─── Judge ────────────────────────────────────────────────────────────────────
JUDGE_CONCURRENCY="4"
JUDGE_TIMEOUT_MS="10000"
DOCKER_SOCKET="/var/run/docker.sock"

# ─── Judge Docker Images ──────────────────────────────────────────────────────
DOCKER_IMAGE_CPP="campus-quest-judge-cpp:latest"
DOCKER_IMAGE_JAVA="campus-quest-judge-java:latest"
DOCKER_IMAGE_PYTHON="campus-quest-judge-python:latest"
DOCKER_IMAGE_JS="campus-quest-judge-js:latest"
