  "views": {
    "public.leaderboard": {
      "columns": {
        "team_id": {
          "name": "team_id",
          "type": "text",
          "primaryKey": false,
          "notNull": true
        }
      },
      "definition": "select \"team_id\", count(distinct case when \"verdict\" = 'AC' then \"problem_id\" end) as \"solved\", \n        coalesce(sum(\n          case\n            when \"verdict\" = 'AC' then\n              extract(epoch from (\"created_at\" - (select started_at from contests limit 1))) / 60\n              + 20 * (\n                select count(*) from submissions s2\n                where s2.team_id = \"team_id\"\n                  and s2.problem_id = \"problem_id\"\n                  and s2.verdict != 'AC'\n                  and s2.created_at < \"created_at\"\n              )\n            else 0\n          end\n        ), 0)\n       as \"penalty\", coalesce(sum(case when \"verdict\" = 'AC' then \"runtime_ms\" else 0 end), 0) as \"best_runtime\" from \"submissions\" group by \"submissions\".\"team_id\"",
      "name": "leaderboard",
      "schema": "public",
      "isExisting": false,
      "materialized": false
    }
  },
